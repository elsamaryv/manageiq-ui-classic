          </button>
        </div>
      </div>
    </div>
    <div
      class="service-dialog-form__footer"
    >
      <button
        class="cds--btn cds--btn--primary"
        type="button"
      >
        Add
      </button>
      <button
        class="cds--btn cds--btn--secondary"
        type="button"
      >
        Cancel
      </button>
    </div>
  </div>
</div>
`;
